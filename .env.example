# ─────────────────────────────────────────────────────────
#  HybridRAG — Environment Configuration
#  Copy this file to .env and fill in your values
#  .env is gitignored — never commit your real keys!
# ─────────────────────────────────────────────────────────

# ── OpenAI (leave blank to use Ollama only) ──────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── ChromaDB Auth Token ───────────────────────────────────
CHROMA_TOKEN=hybridrag-secret-change-me

# ── Default Models ────────────────────────────────────────
DEFAULT_LOCAL_MODEL=llama3.1
DEFAULT_EMBED_MODEL=nomic-embed-text

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info

# ── Router Thresholds ────────────────────────────────────
# Queries above this complexity score go to OpenAI
COMPLEXITY_THRESHOLD=0.7
# Max tokens before routing to cloud
LOCAL_MAX_TOKENS=2048
